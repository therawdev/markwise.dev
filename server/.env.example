# --- Database ---
DATABASE_URL=postgres://markwise:markwise_dev@localhost:5432/markwise

# --- Auth ---
JWT_SECRET=change-me-in-production
# Seeded application owner (created by `npm run seed`)
APP_OWNER_EMAIL=admin@markwise.dev
APP_OWNER_PASSWORD=

# --- Server ---
PORT=3000

# --- AI providers ---
# Active provider: codex | claude_code | claude
AI_PROVIDER=codex

# OpenAI Codex SDK (active default)
OPENAI_API_KEY=

# Claude Code headless CLI (available)
# Requires the `claude` CLI to be installed and authenticated on the host.
CLAUDE_CODE_BIN=claude

# Claude SDK / Claude API — DISABLED for this session.
# Set CLAUDE_API_ENABLED=true AND provide ANTHROPIC_API_KEY to enable.
CLAUDE_API_ENABLED=false
ANTHROPIC_API_KEY=
