# --- Database ---
DATABASE_URL=postgres://markwise:markwise_dev@localhost:5432/markwise

# --- Auth ---
JWT_SECRET=change-me-in-production
# Seeded application owner (created by `npm run seed`)
APP_OWNER_EMAIL=admin@markwise.dev
APP_OWNER_PASSWORD=

# --- Server ---
PORT=3000

# --- AI providers ---
# Active provider: gemini | codex | claude_code | claude
# If the active provider fails, the others back it up in that order
# (disable: AI_FAILOVER=false).
AI_PROVIDER=gemini

# OpenAI Codex SDK (active default)
OPENAI_API_KEY=

# Claude Code headless CLI (available)
# Requires the `claude` CLI to be installed and authenticated on the host.
CLAUDE_CODE_BIN=claude
# Model for the headless CLI (alias like haiku/sonnet/opus or a full model id).
# The app's prompts are small one-shot JSON tasks — haiku is fast and cheap.
CLAUDE_CODE_MODEL=haiku

# Google Gemini (REST API, no SDK). Works on the free tier.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Claude SDK / Claude API — DISABLED for this session.
# Set CLAUDE_API_ENABLED=true AND provide ANTHROPIC_API_KEY to enable.
CLAUDE_API_ENABLED=false
ANTHROPIC_API_KEY=
